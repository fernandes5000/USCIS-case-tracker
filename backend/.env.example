# Server
HOST=0.0.0.0
PORT=8080

# Database
DATABASE_URL=sqlite:./data/uscis.db

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30

# USCIS API (Sandbox)
USCIS_API_BASE_URL=https://api-int.uscis.gov
USCIS_TOKEN_URL=https://api-int.uscis.gov/oauth/accesstoken
USCIS_CLIENT_ID=your_client_id_here
USCIS_CLIENT_SECRET=your_client_secret_here
